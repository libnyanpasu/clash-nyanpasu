{
  "compilerOptions": {
    "baseUrl": ".",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "composite": true,
    "paths": {
      "@interface/*": ["./frontend/interface/src/*"],
      "@nyanpasu/nyanpasu/*": ["./frontend/nyanpasu/*"],
      "@nyanpasu/interface": ["./frontend/interface/src/index.ts"],
      "@nyanpasu/interface/*": ["./frontend/interface/src/*"],
      "@nyanpasu/utils": ["./frontend/utils/src/index.ts"],
      "@nyanpasu/utils/*": ["./frontend/utils/src/*"],
    },
  },
  "references": [
    { "path": "./frontend/nyanpasu" },
    { "path": "./frontend/interface" },
  ],
}
